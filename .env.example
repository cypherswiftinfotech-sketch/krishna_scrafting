# =========================================
# Application Environment
# =========================================
NODE_ENV=development

# =========================================
# Database (PostgreSQL — Supabase)
# =========================================
# Get this from Supabase Dashboard → Project Settings → Database →
# Connection string → "URI" (use the Transaction or Session pooler
# for serverless; the Direct connection for long-running servers).
#
# Format: postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<POOLER_HOST>:<PORT>/postgres
# Example: postgresql://postgres.abcdefgh:MyPass123@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@YOUR_POOLER_HOST:6543/postgres

# =========================================
# Supabase — client-side (safe to expose to the browser)
# =========================================
# Get these from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# =========================================
# Supabase — server-side (NEVER expose these to the browser)
# =========================================
# Service role bypasses RLS — keep it secret. Only use in server code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: JWT secret for verifying Supabase-issued tokens
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# PostgREST data API endpoint (Dashboard → Settings → API → Data API URL)
SUPABASE_DB_API_URL=https://YOUR_PROJECT_REF.supabase.co/rest/v1/
# Project identifiers (from Dashboard → Settings → General)
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_PROJECT_ID=your_project_uuid

# =========================================
# Authentication (JWT)
# =========================================
# Generate a strong secret with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# =========================================
# Admin Seed Account
# =========================================
# Used by POST /api/admin/seed to create the first admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!StrongPass123

# =========================================
# Cloudinary (image / video uploads)
# =========================================
# Get these from https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: name of an unsigned upload preset configured in Cloudinary dashboard.
# Leave blank if you only use signed uploads.
CLOUDINARY_UPLOAD_PRESET=
